LISTEN_ADDRESS=:8080
LOG_LEVEL=info
REDIS_ADDRESS=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TIMEOUT=3s
PROXY_TIMEOUT=15s
RATE_LIMIT_WINDOW=1m
TOKEN_HASH_SECRET=replace-me
TOKEN_KEY_PREFIX=token
RATE_LIMIT_KEY_PREFIX=ratelimit
STATIC_TOKEN_FILE=development/infrastructure/static-tokens.json
ROUTES=/api/v1/users=http://127.0.0.1:8081,/api/v1/products=http://127.0.0.1:8082
REDIS_PORT=6379
USERS_BACKEND_PORT=8081
PRODUCTS_BACKEND_PORT=8082
